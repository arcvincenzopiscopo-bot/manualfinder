corpus/chroma_db/

# PDF caricati dagli ispettori — persistiti su Supabase Storage
manuali_locali/

# Configurazione locale
.env
.env.*

# Log
*.log
uvicorn.log

# Test e script di sviluppo
test_*.py

# Git
.git/
.gitignore
