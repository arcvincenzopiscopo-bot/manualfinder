# ============================================================
# ManualFinder — .gitignore
# ============================================================

# ── Variabili d'ambiente (contengono API key reali) ──────────
.env
.env.local
.env.production
.env.development
backend/.env

# ── Python: ambienti virtuali (NON caricare) ─────────────────
backend/venv/
backend/.venv/
backend/venv311/
venv/
.venv/
env/

# ── Python standalone (scaricato dal bat, ~50MB) ─────────────
.python311/
.python311.zip

# ── Python: bytecode e cache ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ── Node: dipendenze (rigenerate con npm install) ─────────────
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Frontend: build output ────────────────────────────────────
frontend/dist/
frontend/build/
frontend/.vite/

# ── Logs ─────────────────────────────────────────────────────
*.log
uvicorn.log
vite.log

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Docker override locale ────────────────────────────────────
docker-compose.override.yml

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/

# ── PDF personali alla root (non dati dell'app) ───────────────
# Le schede INAIL sono necessarie → INCLUSE nel repo sia a root che in backend/
*.pdf
!pdf manuali/*.pdf
!backend/pdf manuali/*.pdf
!backend/corpus/raw/normativa/*.pdf

# ── Corpus RAG ───────────────────────────────────────────────
# corpus/raw/      — PDF grezzi root, non committare (grandi, si caricano via admin panel)
# corpus/chroma_db — i file HNSW binari non sono portabili Windows→Linux;
#                    la Docker build li rigenera su Linux da pdf manuali/ (git-tracked).
corpus/raw/
corpus/chroma_db/
corpus/chroma_db_backup/
# backend/corpus/raw/normativa/ — normativa EU git-tracked per Docker build (piccoli PDF)
# backend/corpus/chroma_db/    — generato dalla Docker build, non committare
backend/corpus/chroma_db/
backend/corpus/chroma_db_backup/

# ── Indicizzatore locale — file non necessari nel repo ───────
**/.req_stamp
_upload_tmp.zip
avvia_indicizzatore.ps1
LANCIA_INDICIZZATORE.cmd
