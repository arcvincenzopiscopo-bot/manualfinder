# ============================================================
# ManualFinder — .gitignore
# ============================================================

# ── Variabili d'ambiente (contengono API key reali) ──────────
.env
.env.local
.env.production
.env.development
backend/.env

# ── Python: ambiente virtuale (290MB, NON caricare) ──────────
backend/venv/
backend/.venv/
venv/
.venv/
env/

# ── Python: bytecode e cache ─────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/

# ── Node: dipendenze (rigenerate con npm install) ─────────────
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Frontend: build output ────────────────────────────────────
frontend/dist/
frontend/build/
frontend/.vite/

# ── Logs ─────────────────────────────────────────────────────
*.log
uvicorn.log
vite.log

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE ──────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Docker override locale ────────────────────────────────────
docker-compose.override.yml

# ── Testing ──────────────────────────────────────────────────
coverage/
.nyc_output/

# ── PDF personali alla root (non dati dell'app) ───────────────
# Le schede INAIL in "pdf manuali/" sono necessarie → INCLUSE nel repo
*.pdf
!pdf manuali/*.pdf
