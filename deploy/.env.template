# =============================================================================
# ManualFinder — Variabili d'ambiente produzione
# Copia questo file in deploy/.env e compila i valori
# =============================================================================

# ── AI Providers ──────────────────────────────────────────────────────────────
# Livello 1 (qualità massima, a pagamento)
ANTHROPIC_API_KEY=sk-ant-...
PERPLEXITY_API_KEY=pplx-...

# Livello 2 (gratuito, fallback)
GEMINI_API_KEY=
BRAVE_SEARCH_API_KEY=
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
TAVILY_API_KEY=

# Selezione livello: "auto" (raccomandato) | "1" | "2"
API_TIER=auto

# ── Database ──────────────────────────────────────────────────────────────────
# Supabase transaction pooler (porta 6543)
DATABASE_URL=postgresql://postgres.XXXXX:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_TOKEN=cambia-con-stringa-casuale-lunga

# ── Supabase Storage (PDF caricati dagli ispettori) ──────────────────────────
SUPABASE_URL=https://XXXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_STORAGE_BUCKET=manuali

# ── Server ────────────────────────────────────────────────────────────────────
# Origini permesse per CORS: aggiungi il dominio del frontend Vercel
ALLOWED_ORIGINS=https://manualfinder.vercel.app,http://localhost:5173
ENVIRONMENT=production
RATE_LIMIT_PER_MINUTE=10

# ── PDF ───────────────────────────────────────────────────────────────────────
MAX_PDF_SIZE_MB=50
MAX_PDF_PAGES_PER_CHUNK=30

# Directory PDF locali INAIL (relativa a backend/) — non cambiare
# La cartella fisica è /opt/manualfinder/backend/pdf manuali/
UPLOAD_DIR=manuali_locali
