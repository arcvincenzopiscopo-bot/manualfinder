# ============================================================
# ManualFinder — Variabili d'ambiente
# Sviluppo locale: copia in backend/.env e compila i valori
# Produzione Render: inserisci nel Dashboard Render (Environment)
# ============================================================

# === LIVELLO 1 — API a pagamento (qualità massima) ===
# Anthropic (Claude Vision + Analisi)
# Ottieni su: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Perplexity (Ricerca manuale)
# Ottieni su: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# === LIVELLO 2 — API gratuite (fallback automatico) ===
# Google Gemini Flash — GRATUITO
# Ottieni su: https://aistudio.google.com/app/apikey (no carta di credito)
GEMINI_API_KEY=

# Brave Search — GRATUITO (2.000 query/mese)
# Ottieni su: https://api.search.brave.com
BRAVE_SEARCH_API_KEY=BSA...

# Google Custom Search — GRATUITO (100 query/giorno)
# https://console.cloud.google.com + https://programmablesearchengine.google.com
GOOGLE_CSE_API_KEY=AIza...
GOOGLE_CSE_CX=...

# === SELEZIONE LIVELLO ===
# "auto" = usa il migliore disponibile (consigliato)
# "1"    = forza Livello 1 (a pagamento)
# "2"    = forza Livello 2 (gratuito)
API_TIER=auto

# === CONFIGURAZIONE ===
MAX_PDF_SIZE_MB=50
MAX_PDF_PAGES_PER_CHUNK=30

# CORS — origini consentite (separare con virgola, senza spazi)
# Render: aggiungi https://manualfinder-frontend.onrender.com (o il tuo URL)
ALLOWED_ORIGINS=http://localhost:5173,https://manualfinder-frontend.onrender.com

ENVIRONMENT=development
RATE_LIMIT_PER_MINUTE=10

# ============================================================
# SOLO FRONTEND — solo per Vite build in produzione
# In sviluppo non serve: il proxy /api → localhost:8000 è in vite.config.ts
# In produzione Render: inserisci nel Dashboard del servizio Static Site
# ============================================================
# URL del backend Render (senza slash finale)
# Esempio: https://manualfinder-backend.onrender.com
VITE_API_BASE_URL=
